<?xml version="1.0" encoding="utf-8"?>
<!--
  Base configuration for the SitecoreMCP endpoint.

  Safe by default: the endpoint is DISABLED, HTTPS is required, and writes are off. A disabled
  instance registers no route and behaves exactly like one without the module. Enable and grant
  writes only through an environment-specific patch (see SitecoreMcp.Dev.config.example for local
  development). Never enable writes on a shared instance without a dedicated, limited Sitecore user.
-->
<configuration xmlns:patch="http://www.sitecore.net/xmlconfig/" xmlns:role="http://www.sitecore.net/xmlconfig/role/">
  <sitecore>

    <settings>
      <setting name="Mcp.Enabled" value="false" />
      <setting name="Mcp.EndpointPath" value="sitecore/api/mcp" />
      <setting name="Mcp.RequireHttps" value="true" />
      <setting name="Mcp.AllowWrites" value="false" />
      <setting name="Mcp.MaxRequestBytes" value="1048576" />
      <setting name="Mcp.MaxConcurrentCalls" value="4" />
      <setting name="Mcp.MaxFieldLength" value="2000" />
      <setting name="Mcp.VerboseErrors" value="false" />
      <setting name="Mcp.ServerName" value="SitecoreMcp" />
      <setting name="Mcp.ServerVersion" value="0.1.0" />
      <setting name="Mcp.RateLimit.Capacity" value="30" />
      <setting name="Mcp.RateLimit.RefillPerSecond" value="1" />
    </settings>

    <!-- Keep Sitecore's item-resolution pipeline away from the endpoint. -->
    <settings>
      <setting name="IgnoreUrlPrefixes">
        <patch:attribute name="value">/sitecore/shell/WebService/Service.asmx|/sitecore/api/mcp</patch:attribute>
      </setting>
    </settings>

    <sitecoreMcp type="SitecoreMcp.Server.Transport.McpConfiguration, SitecoreMcp.Server" singleInstance="true">
      <!--
        Clients map an API key to a Sitecore user. The key is never stored here: keyEnvVar names an
        environment variable read at startup. A client whose variable is unset is disabled.
        databases defaults to 'master'; name core or web explicitly to allow them.

        Each <client> MUST carry a unique 'id' attribute. Sitecore's config merge keys collection
        elements by their identifying attribute; two <client> nodes without one collapse into a
        single node (last wins), so only one client is ever handed to AddClient. The id value itself
        is not read by the code - it exists purely to keep the nodes distinct through the merge.
      -->
      <clients hint="raw:AddClient">
        <!-- Defined per-environment. See the dev example patch. -->
      </clients>

      <tools hint="list:AddTool">
        <!-- Read tools -->
        <tool type="SitecoreMcp.Server.Tools.Items.GetContextTool, SitecoreMcp.Server" />
        <tool type="SitecoreMcp.Server.Tools.Items.GetItemTool, SitecoreMcp.Server" />
        <tool type="SitecoreMcp.Server.Tools.Items.GetChildrenTool, SitecoreMcp.Server" />
        <tool type="SitecoreMcp.Server.Tools.Items.GetAncestorsTool, SitecoreMcp.Server" />
        <tool type="SitecoreMcp.Server.Tools.Templates.GetTemplateTool, SitecoreMcp.Server" />
        <tool type="SitecoreMcp.Server.Tools.Templates.ListTemplatesTool, SitecoreMcp.Server" />
        <tool type="SitecoreMcp.Server.Tools.Search.SearchTool, SitecoreMcp.Server" />
        <tool type="SitecoreMcp.Server.Tools.Search.FacetTool, SitecoreMcp.Server" />
        <tool type="SitecoreMcp.Server.Tools.Search.GrepTool, SitecoreMcp.Server" />
        <tool type="SitecoreMcp.Server.Tools.Search.IndexStatusTool, SitecoreMcp.Server" />
        <tool type="SitecoreMcp.Server.Tools.Jobs.GetJobsTool, SitecoreMcp.Server" />
        <tool type="SitecoreMcp.Server.Tools.Items.GetItemReferencesTool, SitecoreMcp.Server" />
        <tool type="SitecoreMcp.Server.Tools.Items.GetItemReferrersTool, SitecoreMcp.Server" />
        <tool type="SitecoreMcp.Server.Tools.Presentation.GetRenderingsTool, SitecoreMcp.Server" />
        <!-- Write tools (hidden unless the client and global switch both allow writes) -->
        <tool type="SitecoreMcp.Server.Tools.Items.CreateItemTool, SitecoreMcp.Server" />
        <tool type="SitecoreMcp.Server.Tools.Templates.CreateTemplateTool, SitecoreMcp.Server" />
        <tool type="SitecoreMcp.Server.Tools.Items.UpdateItemTool, SitecoreMcp.Server" />
        <tool type="SitecoreMcp.Server.Tools.Items.MoveItemTool, SitecoreMcp.Server" />
        <tool type="SitecoreMcp.Server.Tools.Items.CopyItemTool, SitecoreMcp.Server" />
        <tool type="SitecoreMcp.Server.Tools.Items.RenameItemTool, SitecoreMcp.Server" />
        <tool type="SitecoreMcp.Server.Tools.Items.DeleteItemTool, SitecoreMcp.Server" />
        <tool type="SitecoreMcp.Server.Tools.Items.UpdateItemReferrersTool, SitecoreMcp.Server" />
        <tool type="SitecoreMcp.Server.Tools.Publishing.PublishItemTool, SitecoreMcp.Server" />
        <tool type="SitecoreMcp.Server.Tools.Presentation.AddRenderingTool, SitecoreMcp.Server" />
        <tool type="SitecoreMcp.Server.Tools.Presentation.SetRenderingTool, SitecoreMcp.Server" />
        <tool type="SitecoreMcp.Server.Tools.Presentation.RemoveRenderingTool, SitecoreMcp.Server" />
        <tool type="SitecoreMcp.Server.Tools.Presentation.SwitchRenderingTool, SitecoreMcp.Server" />
        <tool type="SitecoreMcp.Server.Tools.Presentation.ResetLayoutTool, SitecoreMcp.Server" />
      </tools>

      <allowedOrigins hint="list:AddOrigin">
      </allowedOrigins>

      <allowedAddresses hint="list:AddAddress">
        <address>127.0.0.1</address>
        <address>::1</address>
      </allowedAddresses>

      <trustedProxies hint="list:AddProxy">
      </trustedProxies>
    </sitecoreMcp>

    <pipelines>
      <initialize>
        <processor type="SitecoreMcp.Server.Transport.McpInitializeProcessor, SitecoreMcp.Server" />
      </initialize>
    </pipelines>

    <!--
      All MCP logging (operational and audit) goes to its own mcp.log via the dedicated
      "SitecoreMcp" logger. additivity="false" keeps it out of the main Sitecore log entirely.
      Audit lines are tagged "AUDIT" so the forensic trail stays greppable within the file.
    -->
    <log4net>
      <appender name="SitecoreMcpAppender" type="log4net.Appender.SitecoreLogFileAppender, Sitecore.Logging">
        <file value="$(dataFolder)/logs/mcp.log.{date}.txt" />
        <appendToFile value="true" />
        <layout type="log4net.Layout.PatternLayout">
          <conversionPattern value="%4t %d{ABSOLUTE} %-5p %m%n" />
        </layout>
        <encoding value="utf-8" />
      </appender>
      <logger name="SitecoreMcp" additivity="false">
        <level value="INFO" />
        <appender-ref ref="SitecoreMcpAppender" />
      </logger>
    </log4net>

  </sitecore>
</configuration>
